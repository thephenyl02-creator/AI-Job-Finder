# Legal Tech Careers - Environment Variables
# Copy this file to .env and fill in your values

# =============================================
# REQUIRED
# =============================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/legaltechcareers

# Session encryption key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=

# Your app's public URL (no trailing slash)
APP_URL=https://yourdomain.com

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Stripe keys (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe webhook signing secret (from webhook endpoint settings)
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================
# OPTIONAL
# =============================================

# OpenAI base URL (only if using Azure OpenAI or a proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Google OAuth (enables "Sign in with Google" button)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Server port (default: 5000)
# PORT=5000
